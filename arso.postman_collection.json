{
  "info": {
    "name": "Arso - Pruebas Postman",
    "description": "Colección completa de pruebas para el proyecto Arso (4 microservicios). Sigue PRUEBAS_POSTMAN.md. Variables de entorno necesarias: pasarela, usuarios, productos, compraventas, jwtAdmin, jwtVendedor, jwtComprador, idAdmin, idVendedor, idComprador, idCategoria, idProducto, idCompraventa.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "pasarela", "value": "http://localhost:9090" },
    { "key": "usuarios", "value": "http://localhost:8080" },
    { "key": "productos", "value": "http://localhost:8083" },
    { "key": "compraventas", "value": "http://localhost:8082" },
    { "key": "jwtAdmin", "value": "" },
    { "key": "jwtVendedor", "value": "" },
    { "key": "jwtComprador", "value": "" },
    { "key": "idAdmin", "value": "" },
    { "key": "idVendedor", "value": "" },
    { "key": "idComprador", "value": "" },
    { "key": "idCategoria", "value": "" },
    { "key": "idProducto", "value": "" },
    { "key": "idCompraventa", "value": "" }
  ],
  "item": [
    {
      "name": "B. End-to-end (camino feliz)",
      "item": [
        {
          "name": "B.1.a Alta Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const loc = pm.response.headers.get('Location');",
                  "if (loc) pm.environment.set('idAdmin', loc.split('/').pop());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Alejandro\",\n  \"apellidos\": \"Admin\",\n  \"email\": \"admin@test.com\",\n  \"clave\": \"admin1234\",\n  \"fechaNacimiento\": \"2000-01-01\",\n  \"telefono\": \"600000001\",\n  \"admin\": true\n}"
            },
            "url": { "raw": "{{usuarios}}/api/usuarios", "host": ["{{usuarios}}"], "path": ["api", "usuarios"] }
          }
        },
        {
          "name": "B.1.b Alta Vendedor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const loc = pm.response.headers.get('Location');",
                  "if (loc) pm.environment.set('idVendedor', loc.split('/').pop());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Vendedor\",\n  \"apellidos\": \"Test\",\n  \"email\": \"vendedor@test.com\",\n  \"clave\": \"vend1234\",\n  \"fechaNacimiento\": \"2000-01-01\",\n  \"telefono\": \"600000002\",\n  \"admin\": false\n}"
            },
            "url": { "raw": "{{usuarios}}/api/usuarios", "host": ["{{usuarios}}"], "path": ["api", "usuarios"] }
          }
        },
        {
          "name": "B.1.c Alta Comprador",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const loc = pm.response.headers.get('Location');",
                  "if (loc) pm.environment.set('idComprador', loc.split('/').pop());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Comprador\",\n  \"apellidos\": \"Test\",\n  \"email\": \"comprador@test.com\",\n  \"clave\": \"comp1234\",\n  \"fechaNacimiento\": \"2000-01-01\",\n  \"telefono\": \"600000003\",\n  \"admin\": false\n}"
            },
            "url": { "raw": "{{usuarios}}/api/usuarios", "host": ["{{usuarios}}"], "path": ["api", "usuarios"] }
          }
        },
        {
          "name": "B.2.a Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.environment.set('jwtAdmin', j.token);",
                  "if (j.identificador) pm.environment.set('idAdmin', j.identificador);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"clave\": \"admin1234\"\n}"
            },
            "url": { "raw": "{{pasarela}}/auth/login", "host": ["{{pasarela}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "B.2.b Login Vendedor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.environment.set('jwtVendedor', j.token);",
                  "if (j.identificador) pm.environment.set('idVendedor', j.identificador);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vendedor@test.com\",\n  \"clave\": \"vend1234\"\n}"
            },
            "url": { "raw": "{{pasarela}}/auth/login", "host": ["{{pasarela}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "B.2.c Login Comprador",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.environment.set('jwtComprador', j.token);",
                  "if (j.identificador) pm.environment.set('idComprador', j.identificador);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"comprador@test.com\",\n  \"clave\": \"comp1234\"\n}"
            },
            "url": { "raw": "{{pasarela}}/auth/login", "host": ["{{pasarela}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "B.3 Listar Categorias (guarda idCategoria)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const arr = pm.response.json();",
                  "if (Array.isArray(arr) && arr.length > 0) pm.environment.set('idCategoria', arr[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{productos}}/productos/categorias", "host": ["{{productos}}"], "path": ["productos", "categorias"] }
          }
        },
        {
          "name": "B.4 Crear Producto (Vendedor)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const loc = pm.response.headers.get('Location');",
                  "if (loc) pm.environment.set('idProducto', loc.split('/').pop());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtVendedor}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Bicicleta de montaña\",\n  \"descripcion\": \"Bici en buen estado\",\n  \"precio\": 150.0,\n  \"estado\": \"BUEN_ESTADO\",\n  \"idCategoria\": \"{{idCategoria}}\",\n  \"envioDisponible\": true,\n  \"idVendedor\": \"{{idVendedor}}\"\n}"
            },
            "url": { "raw": "{{pasarela}}/api/productos", "host": ["{{pasarela}}"], "path": ["api", "productos"] }
          }
        },
        {
          "name": "B.5 Asignar lugar recogida",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('204 No Content', () => pm.response.to.have.status(204));"]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtVendedor}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descripcion\": \"Plaza Circular, Murcia\",\n  \"latitud\": 37.9922,\n  \"longitud\": -1.1307\n}"
            },
            "url": { "raw": "{{pasarela}}/api/productos/{{idProducto}}/recogida", "host": ["{{pasarela}}"], "path": ["api", "productos", "{{idProducto}}", "recogida"] }
          }
        },
        {
          "name": "B.6 GET Producto (público)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{pasarela}}/api/productos/{{idProducto}}", "host": ["{{pasarela}}"], "path": ["api", "productos", "{{idProducto}}"] }
          }
        },
        {
          "name": "B.7 Búsqueda de productos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{pasarela}}/api/productos/buscar?texto=Bicicleta",
              "host": ["{{pasarela}}"],
              "path": ["api", "productos", "buscar"],
              "query": [{ "key": "texto", "value": "Bicicleta" }]
            }
          }
        },
        {
          "name": "B.8 Añadir visualización",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('204 No Content', () => pm.response.to.have.status(204));"]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{pasarela}}/api/productos/{{idProducto}}/visualizaciones", "host": ["{{pasarela}}"], "path": ["api", "productos", "{{idProducto}}", "visualizaciones"] }
          }
        },
        {
          "name": "B.9 Crear Compraventa (Comprador)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const loc = pm.response.headers.get('Location');",
                  "if (loc) pm.environment.set('idCompraventa', loc.split('/').pop());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtComprador}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idProducto\": \"{{idProducto}}\",\n  \"idComprador\": \"{{idComprador}}\"\n}"
            },
            "url": { "raw": "{{pasarela}}/api/compraventas", "host": ["{{pasarela}}"], "path": ["api", "compraventas"] }
          }
        },
        {
          "name": "B.11 GET Compraventa por id (HATEOAS)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtComprador}}" }],
            "url": { "raw": "{{pasarela}}/api/compraventas/{{idCompraventa}}", "host": ["{{pasarela}}"], "path": ["api", "compraventas", "{{idCompraventa}}"] }
          }
        },
        {
          "name": "B.12 Comprador ve sus compras",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtComprador}}" }],
            "url": { "raw": "{{pasarela}}/api/compraventas/compras/{{idComprador}}", "host": ["{{pasarela}}"], "path": ["api", "compraventas", "compras", "{{idComprador}}"] }
          }
        },
        {
          "name": "B.13 Vendedor ve sus ventas",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtVendedor}}" }],
            "url": { "raw": "{{pasarela}}/api/compraventas/ventas/{{idVendedor}}", "host": ["{{pasarela}}"], "path": ["api", "compraventas", "ventas", "{{idVendedor}}"] }
          }
        },
        {
          "name": "B.14 Admin ve transacciones entre dos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwtAdmin}}" }],
            "url": {
              "raw": "{{pasarela}}/api/compraventas?idComprador={{idComprador}}&idVendedor={{idVendedor}}",
              "host": ["{{pasarela}}"],
              "path": ["api", "compraventas"],
              "query": [
                { "key": "idComprador", "value": "{{idComprador}}" },
                { "key": "idVendedor", "value": "{{idVendedor}}" }
              ]
            }
          }
        },
        {
          "name": "B.15 Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{pasarela}}/auth/logout", "host": ["{{pasarela}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "C. Validación feedback profesor",
      "item": [
        {
          "name": "C.1 Tras logout, GET compraventa sin token -> 401",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"] }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{pasarela}}/api/compraventas/{{idCompraventa}}", "host": ["{{pasarela}}"], "path": ["api", "compraventas", "{{idCompraventa}}"] }
          }
        },
        {
          "name": "C.4.a Producto: titulo vacío -> 400",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('400 Bad Request', () => pm.response.to.have.status(400));"] } }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtVendedor}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"\",\n  \"precio\": 10,\n  \"estado\": \"NUEVO\",\n  \"idCategoria\": \"{{idCategoria}}\",\n  \"idVendedor\": \"{{idVendedor}}\"\n}" },
            "url": { "raw": "{{pasarela}}/api/productos", "host": ["{{pasarela}}"], "path": ["api", "productos"] }
          }
        },
        {
          "name": "C.4.b Producto: precio negativo -> 400",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('400 Bad Request', () => pm.response.to.have.status(400));"] } }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtVendedor}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"X\",\n  \"precio\": -1,\n  \"estado\": \"NUEVO\",\n  \"idCategoria\": \"{{idCategoria}}\",\n  \"idVendedor\": \"{{idVendedor}}\"\n}" },
            "url": { "raw": "{{pasarela}}/api/productos", "host": ["{{pasarela}}"], "path": ["api", "productos"] }
          }
        },
        {
          "name": "C.4.c Producto: falta idVendedor -> 400",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('400 Bad Request', () => pm.response.to.have.status(400));"] } }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtVendedor}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"X\",\n  \"precio\": 10,\n  \"estado\": \"NUEVO\",\n  \"idCategoria\": \"{{idCategoria}}\"\n}" },
            "url": { "raw": "{{pasarela}}/api/productos", "host": ["{{pasarela}}"], "path": ["api", "productos"] }
          }
        },
        {
          "name": "C.4.d Producto: falta idCategoria -> 400",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('400 Bad Request', () => pm.response.to.have.status(400));"] } }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtVendedor}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"X\",\n  \"precio\": 10,\n  \"estado\": \"NUEVO\",\n  \"idVendedor\": \"{{idVendedor}}\"\n}" },
            "url": { "raw": "{{pasarela}}/api/productos", "host": ["{{pasarela}}"], "path": ["api", "productos"] }
          }
        },
        {
          "name": "C.4.e Producto: falta estado -> 400",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('400 Bad Request', () => pm.response.to.have.status(400));"] } }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtVendedor}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"X\",\n  \"precio\": 10,\n  \"idCategoria\": \"{{idCategoria}}\",\n  \"idVendedor\": \"{{idVendedor}}\"\n}" },
            "url": { "raw": "{{pasarela}}/api/productos", "host": ["{{pasarela}}"], "path": ["api", "productos"] }
          }
        },
        {
          "name": "C.4.f Recogida: latitud fuera de rango -> 400",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('400 Bad Request', () => pm.response.to.have.status(400));"] } }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtVendedor}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"descripcion\": \"X\",\n  \"latitud\": 200,\n  \"longitud\": 0\n}" },
            "url": { "raw": "{{pasarela}}/api/productos/{{idProducto}}/recogida", "host": ["{{pasarela}}"], "path": ["api", "productos", "{{idProducto}}", "recogida"] }
          }
        },
        {
          "name": "C.4.g Recogida: longitud fuera de rango -> 400",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('400 Bad Request', () => pm.response.to.have.status(400));"] } }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtVendedor}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"descripcion\": \"X\",\n  \"latitud\": 0,\n  \"longitud\": 500\n}" },
            "url": { "raw": "{{pasarela}}/api/productos/{{idProducto}}/recogida", "host": ["{{pasarela}}"], "path": ["api", "productos", "{{idProducto}}", "recogida"] }
          }
        },
        {
          "name": "C.4.h Recogida: descripción vacía -> 400",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('400 Bad Request', () => pm.response.to.have.status(400));"] } }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtVendedor}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"descripcion\": \"\",\n  \"latitud\": 40,\n  \"longitud\": -3\n}" },
            "url": { "raw": "{{pasarela}}/api/productos/{{idProducto}}/recogida", "host": ["{{pasarela}}"], "path": ["api", "productos", "{{idProducto}}", "recogida"] }
          }
        },
        {
          "name": "C.4.i Modificar producto: precio negativo -> 400",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('400 Bad Request', () => pm.response.to.have.status(400));"] } }
          ],
          "request": {
